# ── StudioAITube – Variáveis de ambiente ──────────────────────────
# Copie este arquivo para .env.local (desenvolvimento) ou configure
# direto no painel do Netlify (Site settings → Environment variables).

# ── Obrigatórias para o Studio funcionar ──
OPENROUTER_API_KEY=sk-or-...           # Roteiros + imagens (openrouter.ai)
REPLICATE_API_KEY=r8_...               # Animações imagem→vídeo (replicate.com)

# ── Opcionais (fallbacks / features extras) ──
LOVABLE_API_KEY=                        # Fallback para imagens e TTS via Lovable
ELEVENLABS_API_KEY=                     # TTS premium (elevenlabs.io) – sem isso usa Google TTS gratuito
LOVABLE_CONNECTOR_REPLICATE_API_KEY=    # Alt. Replicate via conector Lovable